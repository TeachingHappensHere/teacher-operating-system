(() => {
  "use strict";
  const CHECKS_KEY="thh-v71:launch-readiness";
  let installPrompt=null;
  const $=(s,r=document)=>r.querySelector(s), $$=(s,r=document)=>[...r.querySelectorAll(s)];
  const esc=v=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");
  const parse=v=>{try{return JSON.parse(v)}catch{return null}};
  const toast=m=>{const t=$("#toast");if(!t)return;t.textContent=m;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),1800)};
  const standalone=()=>matchMedia("(display-mode: standalone)").matches||navigator.standalone===true;
  function wait(){if(!$("#mainNav")||!$("#pageHost"))return setTimeout(wait,100);addNav();addInstall();observeDashboard();observeHealth()}
  function addNav(){if($("#v71LaunchButton"))return;const b=document.createElement("button");b.id="v71LaunchButton";b.className="nav-button v71-launch-nav";b.innerHTML="<span>★</span><strong>Launch Readiness</strong>";b.onclick=openReadiness;const h=$('[data-route="health"]');h?h.before(b):$("#mainNav").appendChild(b)}
  function addInstall(){if($("#installAppButton"))return;const b=document.createElement("button");b.id="installAppButton";b.className="install-pill";b.textContent=standalone()?"✓ Installed":"Install App";b.disabled=standalone();b.onclick=installApp;$("#profileButton")?.before(b)}
  async function installApp(){if(standalone())return toast("The app is already installed.");if(!installPrompt)return toast("Use the browser menu and choose Install App or Add to Home Screen.");installPrompt.prompt();await installPrompt.userChoice;installPrompt=null}
  addEventListener("beforeinstallprompt",e=>{e.preventDefault();installPrompt=e;if($("#installAppButton"))$("#installAppButton").disabled=false});
  function observeDashboard(){const host=$("#pageHost");new MutationObserver(()=>{if(!["","#dashboard"].includes(location.hash)||$("#v71DashboardCard"))return;const h=$(".page-header",host);if(!h)return;const c=parse(localStorage.getItem(CHECKS_KEY))||{},n=Object.values(c).filter(Boolean).length,card=document.createElement("section");card.id="v71DashboardCard";card.className="v71-dashboard-card";card.innerHTML=`<div><p>VERSION 7.1 LAUNCH READINESS</p><h3>${n}/10 launch checks complete</h3><span>Backup, devices, lesson planning, and offline readiness.</span></div><button>Open Checklist</button>`;card.querySelector("button").onclick=openReadiness;h.after(card)}).observe(host,{childList:true,subtree:true})}
  async function openReadiness(){const host=$("#pageHost");let list=['Health page passes all core-file checks','Version 7 backup has been exported','Legacy browser data has been reviewed','Weekly lesson plan is connected','First-day routines are prepared','Calendar contains the next important school dates','App has been tested on desktop','App has been tested on iPad','App has been tested on phone','Offline opening has been tested'];try{const c=await fetch('tos-data.json',{cache:'no-store'}).then(r=>r.json());if(Array.isArray(c.launchReadiness))list=c.launchReadiness}catch{}$$('.nav-button').forEach(x=>x.classList.remove('active'));$('#v71LaunchButton')?.classList.add('active');const checks=parse(localStorage.getItem(CHECKS_KEY))||{};host.innerHTML=`<section class="page-header"><div><p>VERSION 7.1</p><h2>Launch Readiness & Data Bridge</h2><span>Complete these checks before Monday classroom planning.</span></div><button id="v71Health" class="primary-button">Open Health</button></section><section class="v71-readiness-layout"><section class="panel"><h3>Launch Checklist</h3><div class="v71-checklist">${list.map((x,i)=>`<label><input type="checkbox" data-v71="${i}" ${checks[i]?"checked":""}><span>${esc(x)}</span></label>`).join('')}</div></section><section class="panel"><h3>Backup & Transfer</h3><div class="v71-actions"><button id="v71Export" class="primary-button">Export Full Backup</button><button id="v71Import" class="secondary-button">Import Backup</button><button id="v71Legacy" class="secondary-button">Review Legacy Data</button><button id="v71Install" class="secondary-button">${standalone()?"App Installed":"Install App"}</button></div><input id="v71File" type="file" accept=".json,application/json" hidden><div id="v71LegacySummary" class="v71-legacy-summary"></div></section></section><section class="panel"><h3>Device Testing Notes</h3><textarea id="v71Notes" placeholder="Record desktop, iPad, phone, or offline issues...">${esc(parse(localStorage.getItem('thh-v71:device-notes'))||'')}</textarea><button id="v71SaveNotes" class="primary-button">Save Device Notes</button></section>`;$$('[data-v71]').forEach(i=>i.onchange=()=>{const c=parse(localStorage.getItem(CHECKS_KEY))||{};c[i.dataset.v71]=i.checked;localStorage.setItem(CHECKS_KEY,JSON.stringify(c))});$('#v71Health').onclick=()=>$('[data-route="health"]')?.click();$('#v71Export').onclick=exportBackup;$('#v71Import').onclick=()=>$('#v71File').click();$('#v71Legacy').onclick=reviewLegacy;$('#v71Install').onclick=installApp;$('#v71SaveNotes').onclick=()=>{localStorage.setItem('thh-v71:device-notes',JSON.stringify($('#v71Notes').value.trim()));toast('Device notes saved.')};$('#v71File').onchange=importBackup}
  function records(){const out={};for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k?.startsWith('thh-'))out[k]=parse(localStorage.getItem(k))}return out}
  function exportBackup(){const p={application:'TeachingHappensHere',version:'7.1',exportedAt:new Date().toISOString(),records:records()},u=URL.createObjectURL(new Blob([JSON.stringify(p,null,2)],{type:'application/json'})),a=document.createElement('a');a.href=u;a.download=`TeachingHappensHere-v7-1-backup-${new Date().toISOString().slice(0,10)}.json`;a.click();setTimeout(()=>URL.revokeObjectURL(u),500);const c=parse(localStorage.getItem(CHECKS_KEY))||{};c[1]=true;localStorage.setItem(CHECKS_KEY,JSON.stringify(c));toast('Full backup exported.')}
  async function importBackup(e){const f=e.target.files?.[0];if(!f)return;try{const p=JSON.parse(await f.text());if(p.application!=='TeachingHappensHere'||!p.records)throw new Error('Invalid TeachingHappensHere backup.');if(!confirm(`Import ${Object.keys(p.records).length} saved records?`))return;Object.entries(p.records).forEach(([k,v])=>localStorage.setItem(k,JSON.stringify(v)));toast('Backup imported. Reloading...');setTimeout(()=>location.reload(),800)}catch(err){toast(err.message||'Import failed.')}e.target.value=''}
  function reviewLegacy(){const keys=Object.keys(records()).filter(k=>!k.startsWith('thh-v7'));$('#v71LegacySummary').innerHTML=keys.length?`<strong>${keys.length} legacy record(s) found</strong><ul>${keys.map(k=>`<li>${esc(k)}</li>`).join('')}</ul>`:'<strong>No Version 5 or 6 records found on this device.</strong>';const c=parse(localStorage.getItem(CHECKS_KEY))||{};c[2]=true;localStorage.setItem(CHECKS_KEY,JSON.stringify(c))}
  function observeHealth(){const host=$("#pageHost");new MutationObserver(()=>{if(location.hash!=="#health"||$("#v71HealthExtras")||!$("#healthResults"))return;const s=document.createElement("section");s.id="v71HealthExtras";s.className="panel v71-health-extras";s.innerHTML=`<h3>Version 7.1 Launch Checks</h3><div class="health-grid">${healthCard('Installed display mode',standalone(),standalone()?'Installed':'Browser tab')}${healthCard('Online status',navigator.onLine,navigator.onLine?'Online':'Offline')}${healthCard('Backup import support','FileReader' in window,'JSON import')}${healthCard('Storage API',Boolean(navigator.storage),'Browser capability')}</div><div class="button-row"><button id="v71Persist" class="secondary-button">Request Persistent Storage</button><button id="v71Open" class="primary-button">Open Launch Readiness</button></div>`;$('#healthResults').after(s);$('#v71Open').onclick=openReadiness;$('#v71Persist').onclick=async()=>{if(!navigator.storage?.persist)return toast('Persistent storage is not supported.');toast(await navigator.storage.persist()?'Persistent storage granted.':'Persistent storage was not granted.')}}).observe(host,{childList:true,subtree:true})}
  function healthCard(n,o,m){return `<article class="${o?'ready':'missing'}"><strong>${o?'✓':'!'}</strong><div><span>${esc(n)}</span><small>${esc(m)}</small></div></article>`}
  wait();
})();
