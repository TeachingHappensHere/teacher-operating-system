  "classroomLaunchDays": [
    {
      "day": "Day 1",
      "title": "Enter, Belong, Learn the Room",
      "goal": "Students learn how to enter, unpack, gather on the carpet, and begin building classroom community.",
      "routines": [
        "Entering the Classroom",
        "Morning Routine",
        "How to Sit on the Carpet",
        "Restroom Signal",
        "How to Line Up",
        "Dismissal Routine"
      ]
    },
    {
      "day": "Day 2",
      "title": "Practice Transitions",
      "goal": "Students practice moving safely and efficiently between classroom spaces and activities.",
      "routines": [
        "Voice Levels",
        "Pencil Procedures",
        "Partner Talk",
        "Hallway Expectations"
      ]
    },
    {
      "day": "Day 3",
      "title": "Build Independence",
      "goal": "Students begin completing familiar routines with fewer teacher reminders.",
      "routines": [
        "Classroom Jobs",
        "Help Signals",
        "Center Practice",
        "Materials Care"
      ]
    },
    {
      "day": "Day 4",
      "title": "Academic Routines",
      "goal": "Students practice lesson participation, partner work, independent work, and small-group movement.",
      "routines": [
        "I Do / We Do / You Do",
        "Small Groups",
        "Independent Work",
        "Partner Math"
      ]
    },
    {
      "day": "Day 5",
      "title": "Review, Celebrate, Reteach",
      "goal": "Students review routines, celebrate growth, and practice procedures that still need support.",
      "routines": [
        "Routine Review",
        "Compliment Circle",
        "Student Reflection",
        "Reteach High-Need Procedures"
      ]
    }
  ],
